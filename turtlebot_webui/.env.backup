# .env
FLASK_ENV=development
#ROSBRIDGE_IP=
ROSBRIDGE_PORT=
WEB_PORT=5000
SECRET_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FALL_ALERT_COOLDOWN=120
FALL_REQUIRE_CONFIRM=30

#FALL_MODEL_MODE = internal | ros2 | hybrid
FALL_MODEL_MODE = hybrid
FALL_ROS_TOPIC = default /fall/state (expects std_msgs/String with either plain text label or JSON: {"label":"fall","confidence":0.91,"angle":33})
START_STT_TTS_BRIDGE=1
STT_TTS_BRIDGE_CMD="python3 stt_tts_bridge.py"
START_PAN_TILT_NODE=1
PAN_TILT_CMD="python3 pan_tilt_ros_onefile.py --mode teleop"
PAN_TILT_PAN_TOPIC="/pan_tilt/pan_cmd"
PAN_TILT_TILT_TOPIC="/pan_tilt/tilt_cmd"


GENAI_API_KEYS=
GOOGLE_API_KEY=

# STT/TTS Configuration
STT_ENGINE=vosk
VOSK_MODEL_DIR=/STT_Models/vosk-model-small-en-us-0.15
LANGUAGE_HINT=en
VOICE_NAME=Kore
